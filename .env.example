# docker-compose.prod.yml reads from this file. Copy to `.env` and fill in.
# Keep this file in git (no secrets); .env is in .gitignore.

# ── Compose ───────────────────────────────────────────────────────────────
# Used to namespace networks/volumes when co-hosting with another stack.
COMPOSE_PROJECT_NAME=tax-advisor

# ── Database (containerised Postgres) ─────────────────────────────────────
DB_NAME=tax_advisor
DB_USER=postgres
# Generate with:  openssl rand -hex 24
DB_PASSWORD=CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 48
# Backend refuses to start if missing or shorter than 32 chars.
JWT_SECRET=CHANGE_ME

# ── Browser-facing URLs ───────────────────────────────────────────────────
# The React bundle is built with this baked in — set BEFORE first `up --build`.
# Use https://api.yourdomain.com behind a reverse proxy, or http://<ip>:3001
# for a raw IP+port deploy.
REACT_APP_API_URL=http://localhost:3001

# CORS allowlist (comma-separated). Set to the public frontend origin(s).
# Example for the staging deploy:
#   FRONTEND_URL=https://tax.example.com
#   CORS_ORIGINS=https://tax.example.com,https://api.tax.example.com
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
