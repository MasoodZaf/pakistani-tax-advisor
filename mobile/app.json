{
  "expo": {
    "name": "Pakistani Tax Advisor",
    "slug": "pakistani-tax-advisor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "paktaxadvisor",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paktaxadvisor.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.paktaxadvisor.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://tax.aurmak.com/api",
      "google": {
        "iosClientId": "",
        "androidClientId": "",
        "webClientId": ""
      }
    },
    "plugins": [
      "expo-font",
      "expo-sqlite",
      "expo-web-browser"
    ]
  }
}
