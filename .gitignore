# Excel test fixtures — local only, distributed to testers manually.
# The generator script and the generated workbooks both stay out of git.
test-excel-scenarios/
scripts/generate-test-excel.js

# AI consultant knowledge-base PDFs — too large for git (Rules 2002 is 116 MB,
# over GitHub's 100 MB hard limit). Copy locally into backend/data/knowledge-base/
# and `docker cp` into the ai_kb_data volume on prod. Source FBR PDF downloads
# live in repo-root "FBR Docs/" as a staging area, also untracked.
FBR Docs/
backend/data/knowledge-base/*.pdf
backend/data/knowledge-base/*.xlsx

# Audit reports — kept local only (contain a vuln roadmap; not for the public repo)
AUDIT_REPORT_2026-06-01_FULL.md
AUDIT_LIVE_VERIFICATION_2026-06-01.md
AUDIT_P0_FIXES_2026-06-01.md

# graphify knowledge-graph artifacts (interactive HTML, report, raw graph, cache).
# Regenerated locally via /graphify; shared with co-devs as a Downloads zip, not committed.
graphify-out/

# iCloud conflict-copy files (Documents/ is iCloud-synced) — e.g. "Foo 2.js".
# The space before the number is the tell; don't match legit "phase2.js".
* [0-9].js
* [0-9].jsx
* [0-9].ts
* [0-9].tsx
* [0-9].yml
* [0-9].json
