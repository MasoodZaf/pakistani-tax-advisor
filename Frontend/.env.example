# Frontend Environment Configuration

# Backend API URL
REACT_APP_API_URL=http://localhost:3001

# For production, use your deployed API URL:
# REACT_APP_API_URL=https://your-app-name-api.onrender.com
# Google SSO web client ID (public; from Google Cloud Console > Auth Platform > Clients)
REACT_APP_GOOGLE_OAUTH_CLIENT_ID=

# Apple SSO web Services ID (public; Apple Developer portal > Identifiers > Services IDs)
REACT_APP_APPLE_SERVICES_ID=
