# Environment Configuration
NODE_ENV=development
PORT=3001

# Database — must match your running Postgres (Docker or local)
# Prisma connection string (built from the vars below)
DATABASE_URL="postgresql://postgres:your-db-password-here@localhost:5432/tax_advisor?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tax_advisor
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Security — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# App will refuse to start if JWT_SECRET is missing or shorter than 32 chars.
JWT_SECRET=
SESSION_SECRET=

# Test routes — set to "true" ONLY when you need /api/test/* (requires super_admin auth).
# Leave "false" (or unset) in staging/production.
ENABLE_TEST_ROUTES=false

# Super admin bootstrap — used by `node backend/create-super-admin.js`
# Password must be set explicitly; script refuses to run without it.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# Logging
LOG_LEVEL=info

# CORS — allowed origins (comma-separated) + explicit frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000

# ── AI Tax Consultant (DeepSeek) ─────────────────────────────────────────────
# Get a key at https://platform.deepseek.com/ → API Keys.
# Leave blank to disable the AI consultant; the rest of the app still runs.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TIMEOUT_MS=60000

# ── Mobile clients ───────────────────────────────────────────────────────────
# Minimum mobile app version we still accept. Older clients get a 426 with
# an upgrade URL on every request.
MOBILE_MIN_SUPPORTED_VERSION=1.0.0
# REQUIRED in production — where mobile clients should download a new build.
# Marketing landing page, App Store link, or a TestFlight invite URL.
MOBILE_UPGRADE_URL=https://tax.aurmak.com/mobile

# ── Email (Finance-Act admin reminders) ──────────────────────────────────────
# Leave SMTP_HOST blank to keep reminders audit-only (no email sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aurmak.com

# ── Crons ────────────────────────────────────────────────────────────────────
# Set CRON_ENABLED=false in tests / one-off scripts to disable all schedulers.
CRON_ENABLED=true
# Postgres dump retention. Daily/weekly snapshots live under BACKUP_DIR.
BACKUP_DIR=
BACKUP_KEEP_DAILY=14
BACKUP_KEEP_WEEKLY=8

# ── Error reporting (Sentry) ─────────────────────────────────────────────────
# Leave blank to disable Sentry; uncaught exceptions + cron failures will
# still log to winston but won't page anyone.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Object storage (mobile receipts) ─────────────────────────────────────────
# S3-compatible bucket for receipt images. Leave RECEIPT_STORAGE blank to
# return 503 on /api/mobile/v1/receipts (graceful degradation).
RECEIPT_STORAGE=
RECEIPT_S3_BUCKET=
RECEIPT_S3_ENDPOINT=
RECEIPT_S3_REGION=
RECEIPT_S3_ACCESS_KEY=
RECEIPT_S3_SECRET_KEY=

# ── SSO (Google + Apple) ─────────────────────────────────────────────────────
# Allowed ID-token audiences checked by src/services/oidcVerifier.js. Only the
# WEB client ID is needed for the website; mobile/Apple ones arrive with the
# native builds. No client secret is used (ID-token verification flow).
GOOGLE_OAUTH_CLIENT_ID_WEB=
GOOGLE_OAUTH_CLIENT_ID_MOBILE_IOS=
GOOGLE_OAUTH_CLIENT_ID_MOBILE_ANDROID=
APPLE_OAUTH_SERVICE_ID=
APPLE_OAUTH_BUNDLE_ID=