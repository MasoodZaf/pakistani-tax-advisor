# Environment Configuration
NODE_ENV=development
PORT=3001

# Database — must match your running Postgres (Docker or local)
# Prisma connection string (built from the vars below)
DATABASE_URL="postgresql://postgres:your-db-password-here@localhost:5432/tax_advisor?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tax_advisor
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Security — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# App will refuse to start if JWT_SECRET is missing or shorter than 32 chars.
JWT_SECRET=
SESSION_SECRET=

# Test routes — set to "true" ONLY when you need /api/test/* (requires super_admin auth).
# Leave "false" (or unset) in staging/production.
ENABLE_TEST_ROUTES=false

# Super admin bootstrap — used by `node backend/create-super-admin.js`
# Password must be set explicitly; script refuses to run without it.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# Logging
LOG_LEVEL=info

# CORS — allowed origins (comma-separated) + explicit frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000